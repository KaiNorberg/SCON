(do
    (def my-dict (("a" 1) ("b" 2) ("c" 3)))

    (assert! (= (get my-dict "b") 2) "get should return the second item of the matched sub-list")
    (assert! (= (get my-dict "z") ()) "get should return nil if the key is not found")

    (assert! (= (keys my-dict) ("a" "b" "c")) "keys should return a list of all first items")
    
    (assert! (= (values my-dict) (1 2 3)) "values should return a list containing the second items of all sub-lists")

    (assert! (= (assoc my-dict "d" 4) (("a" 1) ("b" 2) ("c" 3) ("d" 4))) "assoc should add a new key-value pair")
    (assert! (= (assoc my-dict "b" 99) (("a" 1) ("b" 99) ("c" 3))) "assoc should replace the value of an existing key")

    (assert! (= (dissoc my-dict "b") (("a" 1) ("c" 3))) "dissoc should remove the sub-list with the matching key")
    (assert! (= (dissoc my-dict "z") my-dict) "dissoc should return the original list if the key is not found")

    (def square (lambda (x) (* x x)))
    (assert! (= (update my-dict "c" square) (("a" 1) ("b" 2) ("c" 9))) "update should apply the lambda to the second item of the matching key")
)